# ---- Backend environment ----
# PostgreSQL connection string (self-hosted, Neon, or Supabase)
DATABASE_URL="postgresql://sdt:sdt@localhost:5432/student_docs?schema=public"

# Port the Express API listens on (Nginx proxies /api here)
PORT=4000

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# CORS: the public origin of the frontend (use your domain in production)
CORS_ORIGIN="http://localhost:5173"

# File uploads
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=10
