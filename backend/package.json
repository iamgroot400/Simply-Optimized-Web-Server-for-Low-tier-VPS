{
  "name": "student-doc-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight Express + Prisma API for the Student Document Tracking System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
